{
  "name": "telecord-server-launcher",
  "version": "1.0.3",
  "description": "Telecord Server Launcher with visual dashboard",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --win"
  },
  "build": {
    "appId": "com.telecord.server-launcher",
    "productName": "Telecord Server",
    "directories": {
      "output": "dist_electron"
    },
    "win": {
      "target": "portable",
      "icon": "icon.ico"
    },
    "files": [
      "main.js",
      "index.html",
      "renderer.js",
      "styles.css",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../server",
        "to": "server",
        "filter": ["**/*"]
      }
    ]
  },
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3"
  }
}
